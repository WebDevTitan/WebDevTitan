                            <ComboBox x:Name="chkChrome" Width="72" Foreground="Black" VerticalAlignment="Center" Height="20"  Margin="0,5,0,0" IsSynchronizedWithCurrentItem ="True" SelectedIndex="{Binding SettingViewModel.SelectedBrowser}">
                                <ComboBoxItem>Chrome</ComboBoxItem>
                                <ComboBoxItem>3rd</ComboBoxItem>
                            </ComboBox>
                            <TextBlock Style="{StaticResource ContentsDescription}" VerticalAlignment="Top" Padding="0,5" TextAlignment="Center" Text="Profile ID" Height="26" Width="65"  Margin="0,0,0,-1"/>
                            <TextBox Style="{StaticResource ContentsValue}" Text="{Binding SettingViewModel.ProfileId}" Width="53" Margin="10,1"/>
                        </StackPanel>
                    </Grid>
                    <Grid Height="35">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55*"/>
                            <ColumnDefinition Width="151*"/>
                            <ColumnDefinition Width="86*"/>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="{StaticResource ControlBorder}" BorderThickness="0 0 0 2" Grid.ColumnSpan="3" />
                        <TextBlock Style="{StaticResource ContentsTitle}" Text="Rest Time" Grid.ColumnSpan="2" Margin="0,9" />
                    </Grid>
                    <Grid Height="25" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ContentsDescription}" TextAlignment="Right" Text="From     " Width="70"/>
                            <ComboBox Name="StartHour" Width="50" ItemsSource="{Binding SettingViewModel.HourList}" SelectedItem="{Binding SettingViewModel.StartHour}" IsSynchronizedWithCurrentItem="True"/>
                            <TextBlock Style="{StaticResource ContentsDescription}" TextAlignment="Center" Text="  To  " Width="50"/>
                            <ComboBox Name="EndHour" Width="50" ItemsSource="{Binding SettingViewModel.HourList1}" SelectedItem="{Binding SettingViewModel.EndHour}" IsSynchronizedWithCurrentItem="True"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>

            </Grid>
        </Grid>
    </Grid>
</Window>
